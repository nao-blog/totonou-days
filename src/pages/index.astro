---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const allPosts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const pinnedPost = allPosts.find(p => p.data.pinned);
const posts = allPosts.filter(p => !p.data.pinned).slice(0, 6);
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<p class="hero-label">ととのう日々へようこそ</p>
				<h1>毎日をちょっとだけ<br />豊かにするヒント</h1>
				<p class="hero-desc">励まし×ライフスタイル。心地よい毎日のためのヒントを届けます。</p>
				<a href="/blog" class="hero-btn">記事を読む</a>
			</section>

			{pinnedPost && (
				<section class="pinned-section">
					<h2 class="section-title">📌 はじめに読んでほしい記事</h2>
					<a href={`/blog/${pinnedPost.id}/`} class="pinned-card">
						<div class="pinned-info">
							<h3 class="pinned-title" set:html={pinnedPost.data.title.replace(/\\n/g, ' ')} />
							{pinnedPost.data.description && (
								<p class="pinned-desc">{pinnedPost.data.description}</p>
							)}
							<span class="pinned-link">読む →</span>
						</div>
					</a>
				</section>
			)}

			<section class="recent-posts">
				<h2 class="section-title">最新の記事</h2>
				<div class="posts-grid">
					{posts.map((post) => (
						<a href={`/blog/${post.id}/`} class="post-card">
							{post.data.heroImage && (
								<Image
									width={600}
									height={300}
									src={post.data.heroImage}
									alt={post.data.title}
									class="post-image"
								/>
							)}
							<div class="post-info">
								<p class="post-date"><FormattedDate date={post.data.pubDate} /></p>
								<h3 class="post-title" set:html={post.data.title.replace(/\\n/g, ' ')} />
								{post.data.description && (
									<p class="post-desc">{post.data.description}</p>
								)}
							</div>
						</a>
					))}
				</div>
				<div class="more-link">
					<a href="/blog">すべての記事を見る →</a>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.pinned-section {
		margin-bottom: 3em;
	}
	.pinned-card {
		display: block;
		background: var(--accent-light);
		border-left: 4px solid var(--accent);
		border-radius: 12px;
		padding: 1.5em 2em;
		text-decoration: none;
		color: inherit;
		transition: transform 0.2s;
	}
	.pinned-card:hover {
		transform: translateY(-2px);
	}
	.pinned-title {
		font-size: 1.2em;
		margin: 0 0 0.5em;
		color: rgb(var(--gray-dark));
	}
	.pinned-desc {
		font-size: 0.9em;
		color: rgb(var(--gray));
		margin: 0 0 0.8em;
	}
	.pinned-link {
		font-size: 0.85em;
		color: var(--accent);
	}

	.hero {
		text-align: center;
		padding: 4em 1em 3em;
		border-bottom: 1px solid rgb(var(--gray-light));
		margin-bottom: 3em;
	}
	.hero-label {
		font-size: 0.85em;
		letter-spacing: 0.15em;
		color: var(--accent);
		text-transform: uppercase;
		margin-bottom: 0.8em;
	}
	.hero h1 {
		font-size: 2.4em;
		margin-bottom: 0.6em;
		line-height: 1.5;
	}
	.hero-desc {
		color: rgb(var(--gray));
		font-size: 1em;
		margin-bottom: 2em;
	}
	.hero-btn {
		display: inline-block;
		background: var(--accent);
		color: white;
		padding: 0.7em 2em;
		border-radius: 100px;
		font-size: 0.95em;
		transition: background 0.2s;
		letter-spacing: 0.05em;
	}
	.hero-btn:hover {
		background: var(--accent-dark);
		color: white;
	}

	.section-title {
		font-size: 1.2em;
		letter-spacing: 0.1em;
		margin-bottom: 1.5em;
		color: rgb(var(--gray));
		font-weight: 400;
	}

	.posts-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 2em;
	}

	.post-card {
		display: block;
		text-decoration: none;
		color: inherit;
		transition: transform 0.2s;
	}
	.post-card:hover {
		transform: translateY(-3px);
	}
	.post-image {
		width: 100%;
		height: 200px;
		object-fit: cover;
		border-radius: 12px;
		margin-bottom: 1em;
	}
	.post-info { }
	.post-date {
		font-size: 0.8em;
		color: rgb(var(--gray));
		margin: 0 0 0.3em;
	}
	.post-title {
		font-size: 1.1em;
		margin: 0 0 0.5em;
		color: rgb(var(--gray-dark));
		line-height: 1.5;
	}
	.post-card:hover .post-title {
		color: var(--accent);
	}
	.post-desc {
		font-size: 0.85em;
		color: rgb(var(--gray));
		margin: 0;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.more-link {
		text-align: center;
		margin-top: 2.5em;
	}
	.more-link a {
		font-size: 0.9em;
		color: var(--accent);
		letter-spacing: 0.05em;
	}

	@media (max-width: 720px) {
		.hero h1 { font-size: 1.7em; }
		.posts-grid { grid-template-columns: 1fr; }
	}
</style>
